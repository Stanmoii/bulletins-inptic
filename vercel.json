{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/api/index.php"
    },
    {
      "handle": "filesystem"
    }
  ]
}
